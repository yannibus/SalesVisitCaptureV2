# This file is used for Git repositories to specify intentionally untracked files that Git should ignore. 
# If you are not using git, you can delete this file. For more information see: https://git-scm.com/docs/gitignore
# For useful gitignore templates see: https://github.com/github/gitignore

# Salesforce cache
.sf/
.sfdx/
.localdevserver/
deploy-options.json

# LWC VSCode autocomplete
**/lwc/jsconfig.json

# LWC Jest coverage reports
coverage/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependency directories
node_modules/

# ApexPMD cache
.pmdCache

# Eslint cache
.eslintcache

# MacOS system files
.DS_Store

# Windows system files
Thumbs.db
ehthumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/

# Local environment variables
.env

# Python Salesforce Functions
**/__pycache__/
**/.venv/
**/venv/

# Tooling & project config (kept local, not published)
.vscode/
.husky/
.cursor/
.claude/
.prettierignore
.prettierrc
.forceignore
eslint.config.js
jest.config.js
package.json
package-lock.json
config/
scripts/*
# But: ship the demo-data SE workflow doc (the _runs/ subfolder stays gitignored via scripts/demo-data/.gitignore)
!scripts/demo-data/
scripts/demo-data/_runs/

# Project-local agent guidance (not for public repo)
CLAUDE.md
